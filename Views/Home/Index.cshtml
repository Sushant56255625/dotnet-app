@model List<TestingApplication.Models.Employee>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1"><i class="bi bi-speedometer2"></i> Employee Dashboard</h3>
        <p class="text-muted mb-0">Manage your workforce at a glance</p>
    </div>
    <a href="/Home/Create" class="btn btn-primary">
        <i class="bi bi-person-plus-fill"></i> Add Employee
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3">
                    <i class="bi bi-people-fill fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Employees</div>
                    <div class="fs-4 fw-semibold">@Model.Count</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Emp ID</th>
                            <th>Name</th>
                            <th>Age</th>
                            <th>Phone</th>
                            <th>Address</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in Model)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@emp.EmpID</span></td>
                                <td class="fw-medium">@emp.EmpName</td>
                                <td>@emp.Age</td>
                                <td>@emp.Phone_Number</td>
                                <td>@emp.Address</td>
                                <td class="text-end">
                                    <a href="/Home/Delete/@emp.ID"
                                       class="btn btn-outline-danger btn-sm"
                                       onclick="return confirm('Are you sure you want to delete this employee?')">
                                        <i class="bi bi-trash3"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-2 mb-0">No employees found. Click <strong>Add Employee</strong> to get started.</p>
            </div>
        }
    </div>
</div>
