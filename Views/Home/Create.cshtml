@model TestingApplication.Models.Employee

@{
    ViewData["Title"] = "Add Employee";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="mb-4">
            <a href="/" class="text-decoration-none text-muted">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>

        <div class="card">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-person-plus"></i> Add New Employee</h5>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Employee ID</label>
                        <input type="number" name="EmpID" class="form-control" placeholder="Enter employee ID" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="EmpName" class="form-control" placeholder="Enter full name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Age</label>
                        <input type="number" name="Age" class="form-control" placeholder="Enter age" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone Number</label>
                        <input type="text" name="Phone_Number" class="form-control" placeholder="Enter phone number" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Address</label>
                        <input type="text" name="Address" class="form-control" placeholder="Enter address" required />
                    </div>
                    <div class="d-flex gap-2 pt-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Save Employee
                        </button>
                        <a href="/" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
